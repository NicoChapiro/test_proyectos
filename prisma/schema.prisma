generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoadmapPriority {
  baja
  media
  alta
  urgente
}

enum RoadmapStatus {
  no_iniciado
  en_curso
  en_riesgo
  bloqueado
  completado
  cancelado
}

enum RoadmapTrafficLight {
  verde
  amarillo
  rojo
  gris
}

enum RoadmapMilestoneStatus {
  not_started
  in_progress
  completed
  blocked
}

enum RoadmapMilestoneTrack {
  supply
  marketing
}

enum RoadmapMilestoneDateMode {
  point
  range
}

enum RoadmapApprovalStatus {
  pending
  approved
  rejected
}

enum RoadmapProjectType {
  packaging
  product_launch
  campaign
  trade_marketing
  ecommerce
  content_design
  event
  innovation
  regulatory_compliance
  internal_process
  other
}

model PackagingRequest {
  id                  String           @id @default(cuid())
  code                String           @unique
  title               String
  description         String?
  requesterName       String
  brand               String?
  category            String?
  status              String           @default("recibida")
  desiredLaunchDate   DateTime?
  sharepointFolderUrl String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  roadmapProjects     RoadmapProject[]

  @@index([status])
  @@index([requesterName])
  @@index([brand])
  @@index([category])
}

model RoadmapProject {
  id                  String              @id @default(cuid())
  code                String              @unique
  name                String
  description         String?
  projectType         RoadmapProjectType  @default(other)
  category            String?
  area                String?
  channel             String?
  brand               String?
  ownerName           String
  priority            RoadmapPriority
  status              RoadmapStatus
  startDate           DateTime
  targetDate          DateTime
  completedAt         DateTime?
  trafficLight        RoadmapTrafficLight
  sourceType          String?
  sourcePackagingId   String?
  sharepointUrl       String?
  sharepointFolderUrl String?
  colorLabel          String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  milestones          RoadmapMilestone[]
  activityLogs        RoadmapActivityLog[]
  roadmapTemplateId   String?
  roadmapTemplate     RoadmapTemplate?     @relation(fields: [roadmapTemplateId], references: [id], onDelete: SetNull)
  packagingRequest    PackagingRequest?   @relation(fields: [sourcePackagingId], references: [id], onDelete: SetNull)

  @@index([startDate, targetDate])
  @@index([status])
  @@index([projectType])
  @@index([ownerName])
  @@index([brand])
  @@index([category])
  @@index([area])
  @@index([channel])
  @@index([sourcePackagingId])
  @@index([roadmapTemplateId])
}

model RoadmapTemplate {
  id          String                     @id @default(cuid())
  name        String
  description String?
  projectType RoadmapProjectType?
  isActive    Boolean                    @default(true)
  sortOrder   Int                        @default(0)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  projects    RoadmapProject[]
  flows       RoadmapTemplateFlow[]
  milestones  RoadmapTemplateMilestone[]

  @@index([isActive, sortOrder])
  @@index([projectType])
}

model RoadmapTemplateFlow {
  id          String                     @id @default(cuid())
  templateId  String
  name        String
  track       RoadmapMilestoneTrack
  sortOrder   Int                        @default(0)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  template    RoadmapTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  milestones  RoadmapTemplateMilestone[]

  @@unique([templateId, track])
  @@index([templateId, sortOrder])
}

model RoadmapTemplateMilestone {
  id                  String                @id @default(cuid())
  templateId          String
  flowId              String
  name                String
  sequence            Int                   @default(0)
  suggestedOwner      String?
  approvalRequired    Boolean               @default(false)
  isCritical          Boolean               @default(false)
  suggestedOffsetDays Int?
  dateMode            RoadmapMilestoneDateMode @default(point)
  suggestedStartOffsetDays Int?
  suggestedEndOffsetDays   Int?
  notes               String?
  sortOrder           Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  template            RoadmapTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  flow                RoadmapTemplateFlow   @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
  @@index([flowId, sequence])
}

model RoadmapMilestone {
  id             String                  @id @default(cuid())
  projectId      String
  name           String
  description    String?
  milestoneCode  String?
  track          RoadmapMilestoneTrack   @default(supply)
  sequence       Int                     @default(0)
  ownerName      String?
  status         RoadmapMilestoneStatus  @default(not_started)
  dueDate        DateTime
  plannedDate    DateTime?
  actualDate     DateTime?
  completedAt    DateTime?
  dateMode       RoadmapMilestoneDateMode @default(point)
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?
  approvalStatus RoadmapApprovalStatus?
  linkUrl        String?
  documentUrl    String?
  notes          String?
  isCritical     Boolean                 @default(false)
  sortOrder      Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  project        RoadmapProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activityLogs   RoadmapActivityLog[]

  @@unique([projectId, milestoneCode])
  @@index([projectId])
  @@index([dueDate])
  @@index([plannedDate])
  @@index([plannedStartDate, plannedEndDate])
  @@index([status])
  @@index([track, sequence])
}

model RoadmapActivityLog {
  id          String            @id @default(cuid())
  projectId   String
  milestoneId String?
  entityType  String
  action      String
  fieldName   String?
  beforeValue String?
  afterValue  String?
  summary     String
  actorName   String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  project     RoadmapProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone   RoadmapMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([milestoneId])
  @@index([action])
}
